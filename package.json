{
  "name": "storytune-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "build:next": "next build",
    "build": "docker compose build",
    "local": "docker compose -f docker-compose.yml -f docker-compose.local.yml up --build -d",
    "local:down": "docker compose -f docker-compose.yml -f docker-compose.local.yml down",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky install",
    "pack": "node scripts/pack.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.9",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "mime-types": "^3.0.2",
    "mongodb": "^7.2.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "sass": "^1.99.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^9.39.0",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@next/eslint-plugin-next": "^16.2.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@testcontainers/mongodb": "^11.14.0",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.0",
    "testcontainers": "^11.14.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{css,scss,sass}": "prettier --write",
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
