# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Application ───────────────────────────────────────────────────────────────
STORYTUNE__SITE_URL=https://www.story-tune.com
STORYTUNE__PORT=3000

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_PASSWORD=CHANGE_ME
STORYTUNE__MONGODB_URI=mongodb://storytune:CHANGE_ME@mongo:27017
STORYTUNE__MONGODB_DB_NAME=storytune
STORYTUNE__MONGODB_MAX_POOL_SIZE=10
STORYTUNE__MONGODB_MIN_POOL_SIZE=2
STORYTUNE__MONGODB_CONNECT_TIMEOUT_MS=30000
STORYTUNE__MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000
STORYTUNE__MONGODB_SOCKET_TIMEOUT_MS=0
STORYTUNE__MONGODB_TLS=false
# STORYTUNE__MONGODB_TLS_CA_FILE=/etc/ssl/certs/mongo-ca.pem
STORYTUNE__MONGODB_AUTH_SOURCE=admin

# ─── JWT ───────────────────────────────────────────────────────────────────────
STORYTUNE__JWT_SECRET=CHANGE_ME_to_a_long_random_string_at_least_32_chars
STORYTUNE__JWT_EXPIRES_IN=7d
STORYTUNE__JWT_ALGORITHM=HS256

# ─── Storage ───────────────────────────────────────────────────────────────────
STORYTUNE__UPLOADED_CARDS_PATH=/opt/storytune/cards
STORYTUNE__INSPIRATION_CARDS_PATH=/opt/storytune/inspiration
# STORYTUNE__TEMP_DIR=/tmp/storytune
STORYTUNE__MAX_UPLOAD_SIZE_MB=50

# ─── Resend ────────────────────────────────────────────────────────────────────
STORYTUNE__RESEND_API_KEY=re_xxxxxxxxxx
STORYTUNE__RESEND_FROM_EMAIL=noreply@story-tune.com
STORYTUNE__RESEND_FROM_NAME=StoryTune

# ─── Mail Templates ────────────────────────────────────────────────────────────
STORYTUNE__MAIL_TEMPLATE_DIR=/opt/storytune/emails/templates

# ─── Logging ───────────────────────────────────────────────────────────────────
# STORYTUNE__LOG_LEVEL=info

# ─── Admin Seed (first-run only) ───────────────────────────────────────────────
STORYTUNE__ADMIN_USERNAME=admin
STORYTUNE__ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
