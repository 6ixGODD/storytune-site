# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.crt
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.dev
!.env.local.example

# local development card/inspiration storage
/local-storage/cards/*
/local-storage/inspiration/*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# aliyun ossutil config
.ossutilconfig

.codepen/
.idea/

# Samples
samples/

# Deploy artifacts
storytune-deploy-*.tar.gz
