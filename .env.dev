# ─── Development environment ──────────────────────────────────────────────────
# Copy this file to .env for production. For local dev use `pnpm dev:local` which
# copies it automatically. Do NOT commit secrets into this file.

NODE_ENV=development

# ─── Application ───────────────────────────────────────────────────────────────
STORYTUNE__SITE_URL=http://localhost:3000
STORYTUNE__PORT=3000

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# docker-compose.dev.yml runs a plain mongo:7 on 27017 with no auth.
STORYTUNE__MONGODB_URI=mongodb://localhost:27017
STORYTUNE__MONGODB_DB_NAME=storytune_dev
STORYTUNE__MONGODB_MAX_POOL_SIZE=5
STORYTUNE__MONGODB_MIN_POOL_SIZE=1
STORYTUNE__MONGODB_CONNECT_TIMEOUT_MS=10000
STORYTUNE__MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
STORYTUNE__MONGODB_SOCKET_TIMEOUT_MS=0
STORYTUNE__MONGODB_TLS=false
STORYTUNE__MONGODB_AUTH_SOURCE=admin

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Dev-only secret — safe to leave as-is on local machines.
STORYTUNE__JWT_SECRET=dev-secret-do-not-use-in-production-32ch
STORYTUNE__JWT_EXPIRES_IN=7d
STORYTUNE__JWT_ALGORITHM=HS256

# ─── Storage ───────────────────────────────────────────────────────────────────
# Card dist files are kept inside the repo under local-storage/ (gitignored).
STORYTUNE__UPLOADED_CARDS_PATH=./local-storage/cards
STORYTUNE__INSPIRATION_CARDS_PATH=./local-storage/inspiration
STORYTUNE__MAX_UPLOAD_SIZE_MB=50

# ─── Resend ────────────────────────────────────────────────────────────────────
# Leave blank in dev — email sending is skipped when the API key is missing.
STORYTUNE__RESEND_API_KEY=
STORYTUNE__RESEND_FROM_EMAIL=dev@localhost
STORYTUNE__RESEND_FROM_NAME=StoryTune Dev

# ─── Logging ───────────────────────────────────────────────────────────────────
STORYTUNE__LOG_LEVEL=debug
STORYTUNE__LOG_TARGETS=[{"type":"stdout"},{"type":"file","path":"./app.log","maxSizeMb":100}]

# ─── Admin Seed ────────────────────────────────────────────────────────────────
STORYTUNE__ADMIN_USERNAME=admin
STORYTUNE__ADMIN_PASSWORD=admin123
