# ─── Local Docker stack environment (.env.local) ───────────────────────────────
# Used by docker-compose.local.yml (full local integration test).
# Copy to .env.local and adjust if needed — most defaults work out of the box.
#
# NOTE: STORYTUNE__MONGODB_URI is injected by docker-compose.local.yml using the
# MONGO_LOCAL_PASSWORD variable (default: storytune-local). You only need to set
# it here if you override MONGO_LOCAL_PASSWORD.

NODE_ENV=production

# ─── Application ───────────────────────────────────────────────────────────────
STORYTUNE__SITE_URL=http://localhost
STORYTUNE__PORT=3000

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# URI is overridden by docker-compose.local.yml; leave as-is.
STORYTUNE__MONGODB_URI=mongodb://storytune:storytune-local@mongo:27017/storytune?authSource=admin
STORYTUNE__MONGODB_DB_NAME=storytune
STORYTUNE__MONGODB_MAX_POOL_SIZE=5
STORYTUNE__MONGODB_MIN_POOL_SIZE=1
STORYTUNE__MONGODB_CONNECT_TIMEOUT_MS=15000
STORYTUNE__MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
STORYTUNE__MONGODB_SOCKET_TIMEOUT_MS=0
STORYTUNE__MONGODB_TLS=false
STORYTUNE__MONGODB_AUTH_SOURCE=admin

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Local-only secret — safe to keep as-is for local testing.
STORYTUNE__JWT_SECRET=local-docker-secret-not-for-production-xx
STORYTUNE__JWT_EXPIRES_IN=7d
STORYTUNE__JWT_ALGORITHM=HS256

# ─── Storage ───────────────────────────────────────────────────────────────────
STORYTUNE__UPLOADED_CARDS_PATH=/opt/storytune/cards
STORYTUNE__INSPIRATION_CARDS_PATH=/opt/storytune/inspiration
STORYTUNE__MAX_UPLOAD_SIZE_MB=50

# ─── Resend ────────────────────────────────────────────────────────────────────
# Leave blank to skip email sending in local tests, or fill in a real key.
STORYTUNE__RESEND_API_KEY=
STORYTUNE__RESEND_FROM_EMAIL=noreply@localhost
STORYTUNE__RESEND_FROM_NAME=StoryTune Local

# ─── Mail Templates ────────────────────────────────────────────────────────────
STORYTUNE__MAIL_TEMPLATE_DIR=/opt/storytune/emails/templates

# ─── Logging ───────────────────────────────────────────────────────────────────
STORYTUNE__LOG_LEVEL=info
STORYTUNE__LOG_TARGETS=[{"type":"stdout"},{"type":"file","path":"/var/log/storytune/app.log","maxSizeMb":100}]

# ─── Admin Seed (first-run only) ───────────────────────────────────────────────
STORYTUNE__ADMIN_USERNAME=admin
STORYTUNE__ADMIN_PASSWORD=admin123
